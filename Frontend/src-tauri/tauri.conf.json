{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "folderbot",
  "version": "0.1.0",
  "identifier": "com.folderbot.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "folderbot",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../shared/icons/32x32.png",
      "../shared/icons/128x128.png",
      "../shared/icons/128x128@2x.png",
      "../shared/icons/icon.icns",
      "../shared/icons/icon.ico"
    ]
  }
}
